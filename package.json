{
	"name": "folder-follow",
	"version": "1.0.0",
	"description": "Auto-collapse the Obsidian file explorer on note switch, with scroll-centering and styling options.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit -p tsconfig.json && node esbuild.config.mjs production",
		"lint": "eslint src",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": ["obsidian", "plugin", "file-explorer"],
	"author": "Josh Glazer",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.9.3",
		"esbuild": "0.28.1",
		"obsidian": "latest",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
