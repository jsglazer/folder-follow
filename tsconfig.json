{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2018",
		"allowSyntheticDefaultImports": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true,
		"lib": ["ES2018", "DOM"],
		"moduleResolution": "bundler",
		"paths": {
			"obsidian": ["./node_modules/obsidian/obsidian.d.ts"]
		}
	},
	"include": ["src/**/*.ts"]
}
